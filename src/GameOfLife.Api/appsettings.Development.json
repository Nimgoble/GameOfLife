{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=gameoflife_dev.db"
  },
  "GameOfLife": {
    "MaxStabilisationIterations": 1000,
    "CycleDetectionDepth": 50,
    "MaxBoardDimension": 500
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "Cors": {
    "DevelopmentAllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000",
      "http://localhost:4173"
    ],
    "AllowCredentials": true
  }
}

